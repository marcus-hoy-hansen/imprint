#!/bin/bash
#SBATCH --job-name=IMPRINTw
#SBATCH --account=nanopore_KGA
##SBATCH --cpus-per-task=1
##SBATCH --mem=1000M
#SBATCH -c 1
#SBATCH --mem 2g
#SBATCH --time=24:00:00
#SBATCH --partition=normal
#SBATCH --output=logs/imprint-watch-20260124-%j.out

set -euo pipefail
umask 002

# shellcheck source=lib.sh
: "${NP_SCRIPT_ROOT:=/faststorage/project/nanopore_kga/workflow_dev/scripts}"
source "${NP_SCRIPT_ROOT}/lib.sh"

INTERVAL="${INTERVAL:-$NP_WATCH_INTERVAL}"           # watcher frequency
WEEKLY_INTERVAL_DAYS="${WEEKLY_INTERVAL_DAYS:-$NP_WEEKLY_INTERVAL_DAYS}"
STATE_DIR="${STATE_DIR:-$NP_WATCH_STATE_DIR}"
LAST_MAINT_FILE="$STATE_DIR/last_maintenance.ts"

WATCH=0
if [[ "${1:-}" == "--watch" ]]; then
  WATCH=1
  shift
fi

EXTRA_ARGS=("$@")

mkdir -p "$STATE_DIR"

maybe_activate_conda "${CONDA_ENV:-base}"

echo "[INFO] Watch run started at $(date)"

# Weekly maintenance (time-based)
now=$(date +%s)
last_maint=0
if [[ -f "$LAST_MAINT_FILE" ]]; then
  last_maint=$(cat "$LAST_MAINT_FILE")
fi

max_age=$(( WEEKLY_INTERVAL_DAYS * 24 * 3600 ))
if (( now - last_maint > max_age )); then
  if [[ -x "${MAINT_CMD:-${NP_SCRIPT_ROOT}/weekly.sh}" ]]; then
    echo "[INFO] Running weekly maintenance"
    "${MAINT_CMD:-${NP_SCRIPT_ROOT}/weekly.sh}"
    echo "$now" > "$LAST_MAINT_FILE"
  else
    echo "[INFO] Weekly maintenance script not found/executable – skipping"
  fi
else
  echo "[INFO] Weekly maintenance not due"
fi

# Run preflight directly (clear SLURM_MEM_* so downstream sbatch submissions don't inherit)
unset SLURM_MEM_PER_CPU SLURM_MEM_PER_GPU SLURM_MEM_PER_NODE
echo "[INFO] Starting preflight: ${NP_SCRIPT_ROOT}/preflight.sh ${EXTRA_ARGS[*]-}"
set +e
"${NP_SCRIPT_ROOT}/preflight.sh" "${EXTRA_ARGS[@]}"
preflight_status=$?
set -e
if (( preflight_status != 0 )); then
  echo "[WARN] preflight.sh exited with status $preflight_status"
fi
echo "[INFO] Preflight finished at $(date)"

# Self-resubmit
if [[ "$WATCH" -eq 1 ]]; then
  echo "[INFO] Rescheduling in $INTERVAL"
  unset SLURM_MEM_PER_CPU SLURM_MEM_PER_GPU SLURM_MEM_PER_NODE
  begin_interval="$INTERVAL"
  if [[ "$begin_interval" =~ ^([0-9]*\.?[0-9]+)hours?$ ]]; then
    hours="${BASH_REMATCH[1]}"
    minutes=$(awk -v h="$hours" 'BEGIN{printf "%.0f", h*60}')
    begin_interval="${minutes}minutes"
  fi
  sbatch --begin=now+${begin_interval} "$0" --watch "${EXTRA_ARGS[@]}"
fi

exit ${preflight_status:-0}
